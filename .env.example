# =====================================================================
# Copy this file to .env (a separate file that is gitignored)
# and fill in your own keys. DO NOT put real keys in this file.
# =====================================================================

# FRED API key (required for HY spread, macro series)
# Get free at: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_api_key_here

# FINRA Data API credentials (optional — for margin debt automation)
# Register at: https://developer.finra.org/
FINRA_CLIENT_ID=
FINRA_CLIENT_SECRET=

# SEC EDGAR User-Agent (recommended — they ask for an identifying UA)
# Format: "Your Name your@email.com"
SEC_USER_AGENT=Personal Research personal@example.com

# Default symbol to focus on
DEFAULT_SYMBOL=QQQ
