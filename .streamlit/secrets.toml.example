# =====================================================================
# Streamlit Community Cloud Secrets template
# 把這個內容貼到 Cloud → App settings → Secrets（不要 commit 真實的 .toml）
# 本機跑用 .env，所以不需要 .streamlit/secrets.toml
# =====================================================================

FRED_API_KEY = "你的_fred_api_key"

# 可選 — 想自動抓 FINRA 才需要
FINRA_CLIENT_ID = ""
FINRA_CLIENT_SECRET = ""

# 建議填 — SEC EDGAR 要求 identifying User-Agent
SEC_USER_AGENT = "Your Name your@email.com"

# 預設標的
DEFAULT_SYMBOL = "QQQ"
