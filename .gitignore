# ====================================================================
# Secrets — NEVER commit
# ====================================================================
.env
*.env.local
.env.production
.env.staging

# ====================================================================
# Python runtime
# ====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environment
.venv/
venv/
env/
ENV/
.python-version

# Build / packaging
build/
dist/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ====================================================================
# Local cache — user-specific downloaded data
# ====================================================================
cache/*
!cache/.gitkeep
# Allow committing reference data files so Streamlit Cloud can read them
# (these sources are login-walled or Cloudflare-blocked from cloud IPs)
!cache/aaii_sentiment.xls
!cache/aaii_sentiment.xlsx
!cache/finra_margin.xlsx
!cache/naaim.xlsx

# ====================================================================
# IDE / editor
# ====================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ====================================================================
# Streamlit
# ====================================================================
.streamlit/secrets.toml

# ====================================================================
# OS junk
# ====================================================================
*.log
.history/
