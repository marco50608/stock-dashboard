# ====================================================================
# Secrets — NEVER commit
# ====================================================================
.env
*.env.local
.env.production
.env.staging

# ====================================================================
# Python runtime
# ====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environment
.venv/
venv/
env/
ENV/
.python-version

# Build / packaging
build/
dist/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ====================================================================
# Local cache — user-specific downloaded data
# ====================================================================
cache/*
!cache/.gitkeep
# Allow committing reference data files so Streamlit Cloud can read them
# (these sources are login-walled or Cloudflare-blocked from cloud IPs)
!cache/aaii_sentiment.xls
!cache/aaii_sentiment.xlsx
!cache/finra_margin.xlsx
!cache/naaim.xlsx
!cache/cboe_pcr.csv
# Canonical CBOE files used by the app (kept small + committed):
!cache/cboe_ratios_wide.csv
!cache/cboe_volume_oi_wide.csv

# Redundant / large CBOE artifacts — keep local-only, do not commit.
# (Wide versions above contain the same info in a smaller, app-friendly shape.)
cache/cboe_raw/
cache/cboe_ratios_long.csv
cache/cboe_volume_oi_long.csv
cache/cboe_put_call_ratios.csv

# ====================================================================
# IDE / editor
# ====================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ====================================================================
# Streamlit
# ====================================================================
.streamlit/secrets.toml

# ====================================================================
# ML — keep local-only until you decide whether to publish
# ====================================================================
utils/ml.py
pages/6_ML_Prediction.py
notebooks/
*.ipynb

# ====================================================================
# OS junk
# ====================================================================
*.log
.history/
